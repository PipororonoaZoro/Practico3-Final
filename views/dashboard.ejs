<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Dashboard de Superhéroes</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <h1>Lista de Superhéroes</h1>

  <a href="/api/heroes/agregar" class="btn">Agregar nuevo héroe</a>

  <table>
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Nombre Real</th>
        <th>Edad</th>
        <th>Planeta</th>
        <th>Poderes</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% superheroes.forEach(hero => { %>
        <tr>
          <td><%= hero.nombre %></td>
          <td><%= hero.nombreReal %></td>
          <td><%= hero.edad %></td>
          <td><%= hero.planeta %></td>
          <td><%= hero.poderes.join(", ") %></td>
          <td>
            <a href="/api/heroes/<%= hero._id %>/editar" class="btn">Editar</a>
            <form action="/api/heroes/<%= hero._id %>?_method=DELETE" method="POST" style="display:inline;">
              <button type="submit" class="btn btn-danger">Eliminar</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</body>
</html>
