<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Agregar nuevo superhéroe</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <h1>Agregar nuevo superhéroe</h1>

  <form action="/api/heroes" method="POST" class="form-card">
    <div class="form-group">
      <label>Nombre del superhéroe:</label>
      <input type="text" name="nombre" required>
    </div>

    <div class="form-group">
      <label>Nombre real:</label>
      <input type="text" name="nombreReal" required>
    </div>

    <div class="form-group">
      <label>Edad:</label>
      <input type="number" name="edad" required>
    </div>

    <div class="form-group">
      <label>Planeta de origen:</label>
      <input type="text" name="planeta" required>
    </div>

    <div class="form-group">
      <label>Poderes (separados por coma):</label>
      <input type="text" name="poderes">
    </div>

    <div class="form-group">
      <label>Aliados (separados por coma):</label>
      <input type="text" name="aliados">
    </div>

    <div class="form-group">
      <label>Enemigos (separados por coma):</label>
      <input type="text" name="enemigos">
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <a href="/api/heroes" class="btn btn-primary">Volver al dashboard</a>
  </form>
</body>
</html>
