<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agregar Superhéroe</title>
</head>
<body>
    <h1>Agregar Superhéroe</h1>

    <form action="/api/heores/agregar" method="POST">
        <label>Nombre del Superhéroe:</label>
        <input type="text " name="nombreSuperHeroe" required minlength="3" maxlength="60"><br><br>

        <label>Nombre Real:</label>
        <input type="text" name="nombreReal" required minlength="3" maxlength="60"><br><br>

        <label>Edad:</label>
        <input type="text" name="Edad" required min="0"><br>><br>

        <label>Planeta Origen:</label>
        <input type="text" name="planetaOrigen"><br><br>

        <label>Debilidad:</label>
        <input type="text" name="debilidad"><br><br>

        <label>Poderes (separados por coma):</label>
        <input type="text" name="poderes" required><br><br>

        <label>Aliados (separados por coma):</label>
        <input type="text" neme="aliados"><br><br>

        <label>Enemigos (separados por coma):</label>
        <input type="text" name="enemigos"><br><br>

        <button type="submit">Agregar</button>

    </form>
    
</body>
</html>