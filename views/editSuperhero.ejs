<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Editar Superhéroe</title>
  <!-- Enlace al CSS -->
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <h1>Editar Superhéroe</h1>

  <form action="/api/heroes/<%= hero._id %>/editar" method="POST">
    <label for="nombre">Nombre:</label>
    <input type="text" id="nombre" name="nombre" value="<%= hero.nombre %>" required>

    <label for="nombreReal">Nombre Real:</label>
    <input type="text" id="nombreReal" name="nombreReal" value="<%= hero.nombreReal %>" required>

    <label for="edad">Edad:</label>
    <input type="number" id="edad" name="edad" value="<%= hero.edad %>" required>

    <label for="planeta">Planeta:</label>
    <input type="text" id="planeta" name="planeta" value="<%= hero.planeta %>" required>

    <label for="poderes">Poderes (separados por coma):</label>
    <input type="text" id="poderes" name="poderes" value="<%= hero.poderes.join(", ") %>">

    <label for="aliados">Aliados (separados por coma):</label>
    <input type="text" id="aliados" name="aliados" value="<%= hero.aliados ? hero.aliados.join(", ") : "" %>">

    <label for="enemigos">Enemigos (separados por coma):</label>
    <input type="text" id="enemigos" name="enemigos" value="<%= hero.enemigos ? hero.enemigos.join(", ") : "" %>">

    <button type="submit">Guardar cambios</button>
  </form>

  <a href="/api/heroes">Volver al Dashboard</a>
</body>
</html>
