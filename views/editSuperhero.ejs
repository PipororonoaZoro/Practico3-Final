<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Editar superhéroe</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <h1>Editar superhéroe</h1>

  <form action="/api/heroes/<%= heroe._id %>?_method=PUT" method="POST" class="form-card">
    <div class="form-group">
      <label>Nombre del superhéroe:</label>
      <input type="text" name="nombre" value="<%= heroe.nombre %>" required>
    </div>

    <div class="form-group">
      <label>Nombre real:</label>
      <input type="text" name="nombreReal" value="<%= heroe.nombreReal %>" required>
    </div>

    <div class="form-group">
      <label>Edad:</label>
      <input type="number" name="edad" value="<%= heroe.edad %>" required>
    </div>

    <div class="form-group">
      <label>Planeta de origen:</label>
      <input type="text" name="planetaOrigen" value="<%= heroe.planetaOrigen %>" required>
    </div>

    <div class="form-group">
      <label>Debilidad:</label>
      <input type="text" name="debilidad" value="<%= heroe.debilidad %>">
    </div>

    <div class="form-group">
      <label>Poderes (separados por coma):</label>
      <input type="text" name="poderes" value="<%= heroe.poderes.join(", ") %>" required>
    </div>

    <div class="form-group">
      <label>Aliados (separados por coma):</label>
      <input type="text" name="aliados" value="<%= heroe.aliados.join(", ") %>">
    </div>

    <div class="form-group">
      <label>Enemigos (separados por coma):</label>
      <input type="text" name="enemigos" value="<%= heroe.enemigos.join(", ") %>">
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-success">Actualizar</button>
      <a href="/api/heroes" class="btn btn-primary">Volver al dashboard</a>
    </div>
  </form>
</body>
</html>
